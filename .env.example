# Configuration Node.js
NODE_ENV=development
PORT=3000

# Configuration MongoDB
# Option 1: MongoDB Local
MONGODB_URI=mongodb://localhost:27017/phenix_tech

# Option 2: MongoDB Atlas (Cloud) - Décommenter et remplir
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/phenix_tech?retryWrites=true&w=majority

# Configuration Frontend
FRONTEND_URL=http://localhost:5500

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345
JWT_EXPIRE=7d

# Email Configuration (Nodemailer)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_or_smtp_password

# Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp

# Pagination
ITEMS_PER_PAGE=50

# API Configuration
API_VERSION=v1
API_TIMEOUT=30000

# ==============================
# PAIEMENT - VRAIES APIs GUINÉE
# ==============================

# === Orange Money Guinée ===
ORANGE_MONEY_API_KEY=your_orange_api_key_here
ORANGE_MONEY_API_SECRET=your_orange_api_secret_here
ORANGE_MONEY_MERCHANT_ID=PHEMIX001
ORANGE_MONEY_API_URL=https://api.orange.com/gn/payment

# === MTN MoMo Guinée ===
MTN_MOMO_API_KEY=your_mtn_api_key_here
MTN_MOMO_API_SECRET=your_mtn_api_secret_here
MTN_MOMO_SUBSCRIPTION_KEY=your_mtn_subscription_key_here
MTN_MOMO_API_URL=https://api.mtn.com/gn/momo

# === Wave ===
WAVE_API_KEY=your_wave_api_key_here
WAVE_BUSINESS_ID=PHEMIX001
WAVE_API_URL=https://gn.api.transferwise.com

# ==============================
# NOTIFICATIONS SMS
# ==============================

# Service SMS principal: 'twilio', 'aws', 'local'
SMS_SERVICE=local

# Twilio Configuration (si SMS_SERVICE=twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Service SMS Local Guinée (si SMS_SERVICE=local)
LOCAL_SMS_API_URL=http://sms-gateway.local/api
LOCAL_SMS_API_KEY=your_local_sms_api_key_here
LOCAL_SMS_SENDER_ID=PHEMIX

# AWS SNS (si SMS_SERVICE=aws)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ==============================
# PAIEMENT LEGACY (Optionnel)
# ==============================

# Stripe (si utilisé)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...

# PayPal (si utilisé)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS Configuration
CORS_ORIGIN=http://localhost:5500
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Database Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 0 * * *

# Sentry (Error Tracking - optional)
SENTRY_DSN=

# Redis (Optional Caching)
REDIS_URL=redis://localhost:6379

# AWS S3 (Optional File Storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# SendGrid (Optional Email Service)
SENDGRID_API_KEY=

# Socket.io Configuration
SOCKET_CORS_ORIGIN=http://localhost:5500
SOCKET_PING_INTERVAL=25000
SOCKET_PING_TIMEOUT=5000

# Admin Configuration
ADMIN_EMAIL=admin@phenixtech.com
ADMIN_PASSWORD=admin123
ADMIN_ROLE=admin

# Notifications
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_PUSH_ENABLED=false

# Analytics
ANALYTICS_ENABLED=true
GOOGLE_ANALYTICS_ID=

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=3600

# Session Configuration
SESSION_SECRET=your_session_secret_change_in_production
SESSION_TIMEOUT=86400

# Timezone
TIMEZONE=Africa/Conakry

# Feature Flags
FEATURE_PAYMENTS=true
FEATURE_REVIEWS=true
FEATURE_WISHLISTS=true
FEATURE_GIFT_CARDS=false

# Debug
DEBUG=false
DEBUG_REQUESTS=false
DEBUG_ERRORS=true
